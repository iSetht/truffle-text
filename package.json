{
  "name": "truffle-text",
  "version": "1.0.3",
  "description": "Scalable deterministic HTML text rendering with certified Flash replay and rich outline rendering.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./packed": {
      "types": "./src/packed.d.ts",
      "import": "./src/packed.js"
    },
    "./richtext": {
      "types": "./src/richtext/parser.d.ts",
      "import": "./src/richtext/parser.js"
    },
    "./styles": {
      "types": "./src/styles/catalog.d.ts",
      "import": "./src/styles/catalog.js"
    },
    "./editable": {
      "types": "./src/editing/editable.d.ts",
      "import": "./src/editing/editable.js"
    },
    "./react": {
      "types": "./src/react.d.ts",
      "import": "./src/react.js"
    }
  },
  "bin": {
    "truffle-setup": "bin/setup.mjs"
  },
  "files": [
    "bin/**/*.mjs",
    "payload/**/*",
    "src/**/*.js",
    "src/**/*.d.ts",
    "README.md",
    "PUBLISHING.md",
    "LICENSE",
    "licenses/**/*",
    "THIRD_PARTY_NOTICES.md"
  ],
  "scripts": {
    "verify": "node ./bin/verify-package.mjs",
    "prepublishOnly": "npm run verify"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "keywords": [
    "truffle",
    "html",
    "canvas",
    "text-rendering",
    "rich-text",
    "flashtype",
    "habbo",
    "pixel-perfect"
  ],
  "license": "MIT"
}
